# Required
DJANGO_SECRET_KEY=          # Must be unique, random, >=50 chars
ANTHROPIC_API_KEY=          # Anthropic API key for AI features

# Required for production
ALLOWED_HOSTS=              # Comma-separated, e.g. pystarter.dev,www.pystarter.dev
CORS_ALLOWED_ORIGINS=       # Comma-separated, e.g. https://pystarter.dev

# Database (production uses PostgreSQL)
DB_NAME=pystarter
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Email (for password reset)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
SENTRY_DSN=                 # Error tracking (frontend ErrorBoundary + backend Sentry SDK)

# Ops: schedule weekly — python manage.py flushexpiredtokens
# (purges expired JWT blacklist entries)
